FLASK_SECRET_KEY=replace_me
JWT_SECRET=replace_me
JWT_EXPIRY_HOURS=720

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_KEEP_ALIVE=15m
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
OLLAMA_DIAGNOSTIC_TIMEOUT_SECONDS=8

# Telegram Bot Setup
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram User Session (Telethon)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELETHON_SESSION_PATH=./sessions/scraper.session

# Admin Notifications
ADMIN_TELEGRAM_CHAT_ID=your_admin_chat_id_here

# Scheduling & Dedup Controls
SCRAPE_INTERVAL_MINUTES=60
DEDUP_SIMILARITY_THRESHOLD=0.88
DEDUP_LOOKBACK_DAYS=30
