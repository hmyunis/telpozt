            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"telegram_chat_id\": \"{{telegram_chat_id}}\",\n  \"timezone\": \"Africa/Addis_Ababa\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register-admin",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register-admin"
              ]
            },
            "description": "Only works once, before any user exists in the database."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = res.getBody();",
                  "if (json && json.success && json.data && json.data.token) {",
                  "  bru.setVar('token', json.data.token);",
                  "}"
                ]
